rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 공통 검증 헬퍼 함수
    // ==========================================
    
    // 필수 필드 포함 확인
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    // 0보다 큰 양수인지 확인
    function isPositiveNumber(field) {
      return request.resource.data[field] is number && request.resource.data[field] > 0;
    }
    
    // 서버 시간 오차 검증 (5분 이내)
    function isRecent(time) {
      return time is timestamp &&
             time > request.time - duration.value(5, 'm') &&
             time <= request.time;
    }
    
    // 클리어 데이터 검증
    function isValidClear() {
      return hasRequiredFields(['gameId', 'attempts', 'timestamp', 'nickname', 'ip', 'device']) &&
             request.resource.data.keys().hasOnly(['gameId', 'attempts', 'timestamp', 'nickname', 'ip', 'device']) &&
             request.resource.data.gameId is string &&
             request.resource.data.gameId.size() == 64 &&
             isPositiveNumber('attempts') &&
             request.resource.data.nickname is string &&
             request.resource.data.nickname.size() <= 20 &&
             request.resource.data.ip is string &&
             request.resource.data.ip.size() <= 45 &&
             request.resource.data.device is string &&
             request.resource.data.device.size() <= 250 &&
             isRecent(request.resource.data.timestamp);
    }

    // 최고 근접 기록 검증
    function isValidClosestGuess() {
      return hasRequiredFields(['gameId', 'score', 'timestamp', 'nickname', 'ip', 'device']) &&
             request.resource.data.keys().hasOnly(['gameId', 'score', 'timestamp', 'nickname', 'ip', 'device']) &&
             request.resource.data.gameId is string &&
             request.resource.data.gameId.size() == 64 &&
             request.resource.data.score is number &&
             request.resource.data.score >= 0 &&
             request.resource.data.score <= 100 &&
             request.resource.data.nickname is string &&
             request.resource.data.nickname.size() <= 20 &&
             request.resource.data.ip is string &&
             request.resource.data.ip.size() <= 45 &&
             request.resource.data.device is string &&
             request.resource.data.device.size() <= 250 &&
             isRecent(request.resource.data.timestamp);
    }

    // 개별 시도 기록 검증
    function isValidAttempt() {
      return hasRequiredFields(['gameId', 'nickname', 'word', 'similarity', 'score', 'timestamp', 'ip', 'device']) &&
             request.resource.data.keys().hasOnly(['gameId', 'nickname', 'word', 'similarity', 'score', 'timestamp', 'ip', 'device']) &&
             request.resource.data.gameId is string &&
             request.resource.data.gameId.size() == 64 &&
             request.resource.data.nickname is string &&
             request.resource.data.nickname.size() <= 20 &&
             request.resource.data.word is string &&
             request.resource.data.word.size() <= 30 &&
             request.resource.data.similarity is number &&
             request.resource.data.score is number &&
             request.resource.data.score >= 0 &&
             request.resource.data.score <= 100 &&
             request.resource.data.ip is string &&
             request.resource.data.ip.size() <= 45 &&
             request.resource.data.device is string &&
             request.resource.data.device.size() <= 250 &&
             isRecent(request.resource.data.timestamp);
    }

    // clears 컬렉션 규칙
    match /clears/{clearId} {
      allow read: if true;
      allow create: if isValidClear();
      allow update, delete: if false;
    }

    // closest_guesses 컬렉션 규칙
    match /closest_guesses/{guessId} {
      allow read: if true;
      allow create: if isValidClosestGuess();
      allow update, delete: if false;
    }

    // attempts 컬렉션 규칙
    match /attempts/{attemptId} {
      allow read: if true;
      allow create: if isValidAttempt();
      allow update, delete: if false;
    }

    // settings 컬렉션 규칙 (백엔드 .env 단어 관리로 마이그레이션되어 쓰기 전면 차단)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
