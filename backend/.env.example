# Guessword 백엔드 설정 템플릿
# 복사하여 .env 파일을 생성해 주세요.

# 보안 수준이 높은 일일 단어 변경 기능을 위한 시크릿 키 (필수)
# 배포 시 반드시 임의의 복잡한 문자열로 변경하세요.
DAILY_WORD_SALT=your-random-secret-string

# words.enc 복호화 마스터 키 (필수)
# encrypt_words.py 가 생성해준 Key를 입력하세요.
WORDS_DECRYPTION_KEY=-dny_kkjZJnU6ik_I0wtaUC1aFnljCKdABsXYTMoTtA=

# 특정 단어로 고정하고 싶을 때만 사용하세요 (테스트용 등). 설정하면 일일 단어 기능이 무시됩니다.
# TARGET_WORD=사과

# CORS 허용 도메인 (쉼표로 구분, * 또는 비워둘 시 전면 허용)
CORS_ORIGINS=*
